   "source": [
    "START\n",
    "SET total = 0\n",
    "WHILE customer has more items\n",
    "    SCAN item\n",
    "    ASK for quantity\n",
    "    CALCULATE item_total = price * quantity\n",
    "    ADD item_total to total\n",
    "END WHILE\n",
    "DISPLAY total\n",
    "ASK for payment method (cash or card)\n",
    "PROCESS payment\n",
    "PRINT receipt\n",
    "END"
   ]
  }
